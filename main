// ────────────────────────────────────────────────────────────────────────────
// FILE: service/AuthService.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.service;

import com.mundial2026.dto.*;
import com.mundial2026.model.User;
import com.mundial2026.repository.UserRepository;
import com.mundial2026.util.JwtUtil;
import lombok.RequiredArgsConstructor;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

@Service
@RequiredArgsConstructor
public class AuthService {

    private final UserRepository userRepo;
    private final PasswordEncoder passwordEncoder;
    private final JwtUtil jwtUtil;

    @Transactional
    public AuthResponse register(RegisterRequest req) {
        if (userRepo.existsByUsername(req.getUsername())) {
            throw new IllegalArgumentException("El nombre de usuario ya está en uso");
        }

        // First registered user becomes admin automatically
        boolean isFirstUser = userRepo.count() == 0;

        User user = User.builder()
                .name(req.getName())
                .username(req.getUsername())
                .passwordHash(passwordEncoder.encode(req.getPassword()))
                .isAdmin(isFirstUser)
                .build();

        userRepo.save(user);
        String token = jwtUtil.generateToken(user);
        return new AuthResponse(token, user.getUsername(), user.getName(), user.isAdmin());
    }

    public AuthResponse login(LoginRequest req) {
        User user = userRepo.findByUsername(req.getUsername())
                .orElseThrow(() -> new IllegalArgumentException("Credenciales incorrectas"));

        if (!user.isActive()) {
            throw new IllegalArgumentException("Cuenta desactivada");
        }

        if (!passwordEncoder.matches(req.getPassword(), user.getPasswordHash())) {
            throw new IllegalArgumentException("Credenciales incorrectas");
        }

        String token = jwtUtil.generateToken(user);
        return new AuthResponse(token, user.getUsername(), user.getName(), user.isAdmin());
    }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: service/ScoreService.java   (CORE SCORING LOGIC)
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.service;

import com.mundial2026.model.*;
import com.mundial2026.repository.*;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

@Service
@RequiredArgsConstructor
@Slf4j
public class ScoreService {

    // ── Scoring constants ──────────────────────────────────────────────────
    public static final int POINTS_EXACT_SCORE   = 5;  // Marcador exacto (bonus)
    public static final int POINTS_CORRECT_OUTCOME = 3;  // Solo acierta el resultado (G/E/P)
    public static final int POINTS_WRONG           = 0;

    private final PredictionRepository predRepo;
    private final ScoreEntryRepository scoreEntryRepo;

    /**
     * Evaluates ALL predictions for a match and awards points.
     * Called by MatchService after an official result is registered.
     */
    @Transactional
    public int evaluatePredictions(Match match) {
        if (match.getStatus() != Match.MatchStatus.FINISHED) {
            throw new IllegalStateException("El partido aún no ha finalizado");
        }

        List<Prediction> predictions = predRepo.findByMatch(match);
        Match.Outcome officialOutcome = match.outcome();
        int evaluated = 0;

        for (Prediction pred : predictions) {
            if (pred.isScored()) {
                log.warn("Prediction {} already scored, skipping", pred.getId());
                continue;
            }

            boolean exact = pred.getPredictedHome() == match.getScoreHome()
                         && pred.getPredictedAway() == match.getScoreAway();

            boolean correctOutcome = pred.predictedOutcome() == officialOutcome;

            int points;
            String reason;

            if (exact) {
                points = POINTS_EXACT_SCORE;
                reason = "EXACT_SCORE";
            } else if (correctOutcome) {
                points = POINTS_CORRECT_OUTCOME;
                reason = "CORRECT_OUTCOME";
            } else {
                points = POINTS_WRONG;
                reason = "WRONG";
            }

            // Update prediction
            pred.setPointsAwarded(points);
            pred.setExact(exact);
            pred.setScored(true);
            predRepo.save(pred);

            // Audit trail
            ScoreEntry entry = ScoreEntry.builder()
                    .user(pred.getUser())
                    .match(match)
                    .points(points)
                    .exact(exact)
                    .reason(reason)
                    .build();
            scoreEntryRepo.save(entry);

            log.info("User {} | Match {} | Pred {}-{} | Official {}-{} | Points: {}",
                    pred.getUser().getUsername(),
                    match.getId(),
                    pred.getPredictedHome(), pred.getPredictedAway(),
                    match.getScoreHome(), match.getScoreAway(),
                    points);

            evaluated++;
        }

        return evaluated;
    }

    /**
     * Returns total accumulated points for a user (sum of all ScoreEntry rows).
     */
    public int getTotalPoints(User user) {
        return scoreEntryRepo.findByUser(user)
                .stream()
                .mapToInt(ScoreEntry::getPoints)
                .sum();
    }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: service/MatchService.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.service;

import com.mundial2026.dto.*;
import com.mundial2026.model.Match;
import com.mundial2026.repository.MatchRepository;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import java.time.LocalDateTime;
import java.util.List;

@Service
@RequiredArgsConstructor
public class MatchService {

    private final MatchRepository matchRepo;
    private final ScoreService scoreService;

    public Match createMatch(MatchRequest req) {
        Match match = Match.builder()
                .homeTeam(req.getHomeTeam())
                .awayTeam(req.getAwayTeam())
                .matchDatetime(req.getMatchDatetime())
                .stage(req.getStage() != null ? req.getStage() : Match.Stage.GRUPOS)
                .groupName(req.getGroupName())
                .build();
        return matchRepo.save(match);
    }

    public List<Match> getAllMatches() {
        return matchRepo.findAllByOrderByMatchDatetimeAsc();
    }

    @Transactional
    public Match registerResult(String matchId, MatchResultRequest req) {
        Match match = matchRepo.findById(matchId)
                .orElseThrow(() -> new IllegalArgumentException("Partido no encontrado"));

        if (match.getStatus() == Match.MatchStatus.FINISHED) {
            throw new IllegalStateException("El partido ya tiene resultado registrado");
        }

        match.setScoreHome(req.getScoreHome());
        match.setScoreAway(req.getScoreAway());
        match.setStatus(Match.MatchStatus.FINISHED);
        match.setFinishedAt(LocalDateTime.now());
        matchRepo.save(match);

        // Trigger score calculation for all predictions
        scoreService.evaluatePredictions(match);

        return match;
    }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: service/PredictionService.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.service;

import com.mundial2026.dto.PredictionRequest;
import com.mundial2026.model.*;
import com.mundial2026.repository.*;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import java.time.LocalDateTime;
import java.util.List;

@Service
@RequiredArgsConstructor
public class PredictionService {

    private final PredictionRepository predRepo;
    private final MatchRepository matchRepo;
    private final UserRepository userRepo;

    @Transactional
    public Prediction saveOrUpdate(String matchId, String username, PredictionRequest req) {
        Match match = matchRepo.findById(matchId)
                .orElseThrow(() -> new IllegalArgumentException("Partido no encontrado"));

        if (match.getStatus() == Match.MatchStatus.FINISHED) {
            throw new IllegalStateException("El partido ya finalizó, no puedes modificar predicciones");
        }

        User user = userRepo.findByUsername(username)
                .orElseThrow(() -> new IllegalArgumentException("Usuario no encontrado"));

        return predRepo.findByMatchAndUser(match, user)
                .map(existing -> {
                    existing.setPredictedHome(req.getPredictedHome());
                    existing.setPredictedAway(req.getPredictedAway());
                    existing.setUpdatedAt(LocalDateTime.now());
                    return predRepo.save(existing);
                })
                .orElseGet(() -> predRepo.save(Prediction.builder()
                        .match(match)
                        .user(user)
                        .predictedHome(req.getPredictedHome())
                        .predictedAway(req.getPredictedAway())
                        .build()));
    }

    public List<Prediction> getMyPredictions(String username) {
        User user = userRepo.findByUsername(username)
                .orElseThrow(() -> new IllegalArgumentException("Usuario no encontrado"));
        return predRepo.findByUser(user);
    }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: service/LeaderboardService.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.service;

import com.mundial2026.dto.LeaderboardEntry;
import com.mundial2026.model.User;
import com.mundial2026.repository.*;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import java.util.*;
import java.util.concurrent.atomic.AtomicInteger;
import java.util.stream.Collectors;

@Service
@RequiredArgsConstructor
public class LeaderboardService {

    private final UserRepository userRepo;
    private final PredictionRepository predRepo;
    private final ScoreService scoreService;

    public List<LeaderboardEntry> getLeaderboard() {
        List<User> users = userRepo.findAll();
        AtomicInteger rank = new AtomicInteger(1);

        return users.stream()
                .map(u -> {
                    var preds = predRepo.findByUser(u);
                    int total = preds.size();
                    int correct = (int) preds.stream().filter(p -> p.getPointsAwarded() > 0).count();
                    int exact   = (int) preds.stream().filter(p -> p.isExact()).count();
                    int pts     = scoreService.getTotalPoints(u);
                    return new LeaderboardEntry(0, u.getUsername(), u.getName(), pts, total, correct, exact);
                })
                .sorted(Comparator.comparingInt(LeaderboardEntry::getTotalPoints).reversed())
                .peek(e -> e.setRank(rank.getAndIncrement()))
                .collect(Collectors.toList());
    }
}


