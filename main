package com.mundial2026.controller;

import com.mundial2026.dto.PredictionRequest;
import com.mundial2026.model.Prediction;
import com.mundial2026.service.PredictionService;
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.security.core.annotation.AuthenticationPrincipal;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.web.bind.annotation.*;
import java.util.List;

@RestController
@RequestMapping("/api/predictions")
@RequiredArgsConstructor
public class PredictionController {

    private final PredictionService predService;

    @GetMapping("/mine")
    public ResponseEntity<List<Prediction>> mine(
            @AuthenticationPrincipal UserDetails userDetails) {
        return ResponseEntity.ok(predService.getMyPredictions(userDetails.getUsername()));
    }

    @PutMapping("/{matchId}")
    public ResponseEntity<Prediction> upsert(
            @PathVariable String matchId,
            @Valid @RequestBody PredictionRequest req,
            @AuthenticationPrincipal UserDetails userDetails) {
        return ResponseEntity.ok(
                predService.saveOrUpdate(matchId, userDetails.getUsername(), req));
    }
}


