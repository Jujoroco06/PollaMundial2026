package com.mundial2026.model;

import jakarta.persistence.*;
import jakarta.validation.constraints.*;
import lombok.*;
import java.time.LocalDateTime;

@Entity
@Table(name = "users")
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class User {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    private String id;

    @NotBlank
    @Size(min = 2, max = 60)
    @Column(nullable = false)
    private String name;

    @NotBlank
    @Size(min = 3, max = 30)
    @Pattern(regexp = "^[a-z0-9_]+$", message = "Solo letras minúsculas, números y guión bajo")
    @Column(unique = true, nullable = false)
    private String username;

    @NotBlank
    @Column(nullable = false)
    private String passwordHash;   // BCrypt hash — NEVER plaintext

    @Builder.Default
    private boolean isAdmin = false;

    @Builder.Default
    @Column(nullable = false)
    private LocalDateTime createdAt = LocalDateTime.now();

    @Builder.Default
    private boolean active = true;
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: model/Match.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.model;

import jakarta.persistence.*;
import lombok.*;
import java.time.LocalDateTime;

@Entity
@Table(name = "matches")
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Match {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    private String id;

    @Column(nullable = false)
    private String homeTeam;

    @Column(nullable = false)
    private String awayTeam;

    private LocalDateTime matchDatetime;

    @Enumerated(EnumType.STRING)
    @Builder.Default
    private Stage stage = Stage.GRUPOS;

    private String groupName;   // "A", "B", etc.

    @Enumerated(EnumType.STRING)
    @Builder.Default
    private MatchStatus status = MatchStatus.PENDING;

    private Integer scoreHome;
    private Integer scoreAway;

    private LocalDateTime finishedAt;

    public enum Stage {
        GRUPOS, OCTAVOS, CUARTOS, SEMIFINAL, FINAL
    }

    public enum MatchStatus {
        PENDING, LIVE, FINISHED
    }

    /** Derives match outcome from official scores */
    public Outcome outcome() {
        if (scoreHome == null || scoreAway == null) return null;
        if (scoreHome > scoreAway) return Outcome.HOME;
        if (scoreAway > scoreHome) return Outcome.AWAY;
        return Outcome.DRAW;
    }

    public enum Outcome { HOME, AWAY, DRAW }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: model/Prediction.java
// ────────────────────────────────────────────────────────────────────────────

package com.mundial2026.model;

import jakarta.persistence.*;
import lombok.*;
import java.time.LocalDateTime;

@Entity
@Table(
    name = "predictions",
    uniqueConstraints = @UniqueConstraint(columnNames = {"match_id", "user_id"})
)
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Prediction {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    private String id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "match_id", nullable = false)
    private Match match;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "user_id", nullable = false)
    private User user;

    @Column(nullable = false)
    private int predictedHome;

    @Column(nullable = false)
    private int predictedAway;

    @Builder.Default
    private int pointsAwarded = 0;

    @Builder.Default
    private boolean exact = false;

    @Builder.Default
    private boolean scored = false;

    @Builder.Default
    private LocalDateTime createdAt = LocalDateTime.now();

    private LocalDateTime updatedAt;

    /** Computes the predicted outcome */
    public Match.Outcome predictedOutcome() {
        if (predictedHome > predictedAway) return Match.Outcome.HOME;
        if (predictedAway > predictedHome) return Match.Outcome.AWAY;
        return Match.Outcome.DRAW;
    }
}


// ────────────────────────────────────────────────────────────────────────────
// FILE: model/ScoreEntry.java  (audit trail of every points transaction)
