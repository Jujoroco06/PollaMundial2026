package com.mundial2026.controller;

import com.mundial2026.dto.*;
import com.mundial2026.model.Match;
import com.mundial2026.service.MatchService;
import jakarta.validation.Valid;
import lombok.RequiredArgsConstructor;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;
import java.util.List;

@RestController
@RequestMapping("/api/matches")
@RequiredArgsConstructor
public class MatchController {

    private final MatchService matchService;

    /** Public: anyone can see the list of matches */
    @GetMapping
    public ResponseEntity<List<Match>> getAll() {
        return ResponseEntity.ok(matchService.getAllMatches());
    }

    /** Admin only: create a match */
    @PreAuthorize("hasRole('ADMIN')")
    @PostMapping
    public ResponseEntity<Match> create(@Valid @RequestBody MatchRequest req) {
        return ResponseEntity.ok(matchService.createMatch(req));
    }

    /** Admin only: register official result → triggers automatic scoring */
    @PreAuthorize("hasRole('ADMIN')")
    @PutMapping("/{id}/result")
    public ResponseEntity<Match> registerResult(
            @PathVariable String id,
            @Valid @RequestBody MatchResultRequest req) {
        return ResponseEntity.ok(matchService.registerResult(id, req));
    }
}


